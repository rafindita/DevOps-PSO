{
  "name": "scholar-seek",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @scholar-seek/db db:push",
    "db:studio": "turbo -F @scholar-seek/db db:studio",
    "db:generate": "turbo -F @scholar-seek/db db:generate",
    "db:migrate": "turbo -F @scholar-seek/db db:migrate",
    "db:seed": "turbo -F @scholar-seek/db db:seed",
    "db:start": "turbo -F @scholar-seek/db db:start",
    "db:watch": "turbo -F @scholar-seek/db db:watch",
    "db:stop": "turbo -F @scholar-seek/db db:stop",
    "db:down": "turbo -F @scholar-seek/db db:down",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@scholar-seek/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@scholar-seek/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^5",
    "ultracite": "7.3.2"
  },
  "packageManager": "bun@1.3.8"
}
